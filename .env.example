PORT=3000
APP_ORIGIN=http://localhost:3000
TRUST_PROXY=false
COOKIE_SECURE=false
SESSION_SECRET=your-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

VPN_SERVER_ENDPOINT=your-server-ip-or-domain:51820
VPN_SERVER_PUBLIC_KEY=your_wireguard_server_public_key
VPN_INTERFACE_NAME=wg0
VPN_SERVER_CONFIG_PATH=/etc/wireguard/wg0.conf
VPN_AUTO_APPLY_PEERS=false
VPN_RELOAD_MODE=manual
